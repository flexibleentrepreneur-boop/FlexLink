  {
    id: 1,
    name: "Adekunle Adeyemi",
    business: "Real Estate Development",
    location: "Lagos, Nigeria",
    matchScore: 92,
    status: "pending",
    reason: "Complementary real estate and interior design services",
    image: "👨‍💼",
  },
  {
    id: 2,
    name: "Zainab Hassan",
    business: "Product Sourcing & Bulk Trading",
    location: "Kano, Nigeria",
    matchScore: 88,
    status: "active",
    reason: "Perfect for cross-selling and bundled solutions",
    image: "👩‍💼",
  },
  {
    id: 3,
    name: "Emeka Okonkwo",
    business: "Beauty & Wellness Services",
    location: "Enugu, Nigeria",
    matchScore: 85,
    status: "pending",
    reason: "Wellness coaching and beauty service integration",
    image: "👨‍💼",
  },
  {
    id: 4,
    name: "Amara Nwosu",
    business: "Travel & Relocation Services",
    location: "Abuja, Nigeria",
    matchScore: 82,
    status: "active",
    reason: "Travel bundles with real estate and wellness",
    image: "👩‍💼",
  },
  {
    id: 5,
    name: "Chioma Okoro",
    business: "Business Consulting",
    location: "Port Harcourt, Nigeria",
    matchScore: 78,
    status: "pending",
    reason: "Business load reduction and entrepreneurship support",
    image: "👩‍💼",
  },
];

export default function Partnerships() {
  const { user, isAuthenticated } = useAuth();
  const [selectedPartner, setSelectedPartner] = useState<number | null>(null);
  const [searchQuery, setSearchQuery] = useState("");
  const [filterStatus, setFilterStatus] = useState<"all" | "active" | "pending">("all");

  const filteredPartners = matchedPartners.filter((p) => {
    const matchesSearch = p.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
      p.business.toLowerCase().includes(searchQuery.toLowerCase());
    const matchesStatus = filterStatus === "all" || p.status === filterStatus;
    return matchesSearch && matchesStatus;
  });

  if (!isAuthenticated) {
    return (
      <div className="min-h-screen bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-white flex items-center justify-center">
        <Card className="border-purple-500/50 bg-slate-800 w-full max-w-md">
          <CardHeader>
            <CardTitle>Sign In Required</CardTitle>
            <CardDescription>Please sign in to view partnership opportunities</CardDescription>
          </CardHeader>
        </Card>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-white">
      {/* Navigation */}
      <nav className="sticky top-0 z-40 border-b border-purple-900/30 bg-slate-950/80 backdrop-blur-md">
        <div className="container mx-auto px-4 py-4 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <Handshake className="w-6 h-6 text-purple-400" />
            <span className="text-xl font-bold bg-gradient-to-r from-purple-400 to-purple-200 bg-clip-text text-transparent">
              Partnership Hub
            </span>
          </div>
          <Button variant="ghost" className="text-slate-400 hover:text-purple-300">
            Back
          </Button>
        </div>
      </nav>

      {/* Main Content */}
      <div className="container mx-auto px-4 py-12">
        {/* Header */}
        <div className="mb-12">
          <h1 className="text-4xl md:text-5xl font-bold mb-4">
            Find Your Perfect <span className="bg-gradient-to-r from-purple-400 to-purple-200 bg-clip-text text-transparent">Partner</span>
          </h1>
          <p className="text-slate-300 text-lg">
            AI-powered matching for collaborations, suppliers, and co-ventures
          </p>
        </div>

        {/* Search and Filter */}
        <div className="mb-8 space-y-4">
          <Input
            placeholder="Search by name or business type..."
            value={searchQuery}
            onChange={(e) => setSearchQuery(e.target.value)}
            className="bg-slate-800 border-purple-900/30 text-white placeholder:text-slate-500"
          />
          <div className="flex gap-3">
            {(["all", "active", "pending"] as const).map((status) => (
              <Button
                key={status}
                onClick={() => setFilterStatus(status)}
                variant={filterStatus === status ? "default" : "outline"}
                className={filterStatus === status ? "bg-gradient-to-r from-purple-600 to-purple-900" : "border-purple-500 text-purple-400"}
              >
                {status.charAt(0).toUpperCase() + status.slice(1)}
              </Button>
            ))}
          </div>
        </div>

        {/* Partnership Grid */}
        <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {filteredPartners.map((partner) => (
            <Card
              key={partner.id}
              className="border-purple-900/50 bg-gradient-to-br from-slate-800 to-slate-900 hover:border-purple-500 transition-all cursor-pointer"
              onClick={() => setSelectedPartner(selectedPartner === partner.id ? null : partner.id)}
            >
              <CardHeader>
                <div className="flex items-start justify-between">
                  <div className="flex items-start gap-4">
                    <div className="text-4xl">{partner.image}</div>
                    <div className="flex-1">
                      <CardTitle className="text-white">{partner.name}</CardTitle>
                      <CardDescription className="text-slate-400">{partner.business}</CardDescription>
                      <p className="text-xs text-slate-500 mt-1">Location: {partner.location}</p>
                    </div>
                  </div>
                  <div className="text-right">
                    <div className="text-3xl font-bold text-purple-400">{partner.matchScore}%</div>
                    <p className="text-xs text-slate-400">Match Score</p>
                  </div>
                </div>
              </CardHeader>

              {selectedPartner === partner.id && (
                <CardContent className="space-y-4 border-t border-purple-900/30 pt-4">
                  <div className="bg-slate-700/50 rounded-lg p-3">
                    <p className="text-sm text-slate-300">
                      <span className="font-semibold text-purple-300">Why matched:</span> {partner.reason}
                    </p>
                  </div>

                  <div className="flex items-center gap-2">
                    <div className="flex-1 flex items-center gap-2">
                      {partner.status === "active" ? (
                        <>
                          <CheckCircle className="w-5 h-5 text-green-400" />
                          <span className="text-sm text-green-300">Partnership Active</span>
                        </>
                      ) : (
                        <>
                          <Clock className="w-5 h-5 text-yellow-400" />
                          <span className="text-sm text-yellow-300">Pending Approval</span>
                        </>
                      )}
                    </div>
                  </div>

                  <div className="flex gap-2">
                    {partner.status === "pending" ? (
                      <>
                        <Button className="flex-1 bg-gradient-to-r from-purple-600 to-purple-900 hover:from-purple-700 hover:to-purple-950">
                          <CheckCircle className="w-4 h-4 mr-2" />
                          Accept
                        </Button>
                        <Button variant="outline" className="flex-1 border-red-500 text-red-400 hover:bg-red-900/20">
                          <XCircle className="w-4 h-4 mr-2" />
                          Decline
                        </Button>
                      </>
                    ) : (
                      <Button className="flex-1 bg-gradient-to-r from-purple-600 to-purple-900 hover:from-purple-700 hover:to-purple-950">
                        <MessageSquare className="w-4 h-4 mr-2" />
                        Message
                      </Button>
                    )}
                  </div>
                </CardContent>
              )}
            </Card>
          ))}
        </div>

        {/* My Partnerships */}
        <div className="mt-12">
          <h2 className="text-2xl font-bold mb-6">
            My <span className="bg-gradient-to-r from-purple-400 to-purple-200 bg-clip-text text-transparent">Active Partnerships</span>
          </h2>
          <div className="space-y-4">
            {matchedPartners
              .filter((p) => p.status === "active")
              .map((partner) => (
                <Card key={partner.id} className="border-green-900/50 bg-gradient-to-br from-slate-800 to-slate-900">
                  <CardContent className="pt-6">
                    <div className="flex items-center justify-between">
                      <div className="flex items-center gap-4">
                        <div className="text-3xl">{partner.image}</div>
                        <div>
                          <h3 className="font-semibold text-white">{partner.name}</h3>
                          <p className="text-sm text-slate-400">{partner.business}</p>
                          <p className="text-xs text-green-400 mt-1">Active Partnership</p>
                        </div>
                      </div>
                      <div className="flex gap-2">
                        <Button size="sm" className="bg-gradient-to-r from-purple-600 to-purple-900 hover:from-purple-700 hover:to-purple-950">
                          <MessageSquare className="w-4 h-4" />
                        </Button>
                        <Button size="sm" variant="outline" className="border-purple-500 text-purple-400 hover:bg-purple-900/20">
                          View Profile
                        </Button>
                      </div>
                    </div>
                  </CardContent>
                </Card>
              ))}
          </div>
        </div>
      </div>
    </div>
  );
}
