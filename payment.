import { useAuth } from "@/_core/hooks/useAuth";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { useState } from "react";
import { CreditCard, Smartphone, DollarSign, CheckCircle } from "lucide-react";

export default function Payment() {
  const { user, isAuthenticated } = useAuth();
  const [amount, setAmount] = useState("");
  const [paymentMethod, setPaymentMethod] = useState<"paystack" | "flutterwave" | "bank" | "opal" | "palmpay">("paystack");
  const [isProcessing, setIsProcessing] = useState(false);
  const [paymentStatus, setPaymentStatus] = useState<"idle" | "processing" | "success" | "error">("idle");

  const paymentMethods = [
    { id: "paystack", name: "Paystack", icon: CreditCard, description: "Card, Bank Transfer" },
    { id: "flutterwave", name: "Flutterwave", icon: CreditCard, description: "Card, Bank, Mobile Money" },
    { id: "bank", name: "Bank Transfer", icon: DollarSign, description: "Direct bank transfer" },
    { id: "opal", name: "OPay", icon: Smartphone, description: "Mobile wallet" },
    { id: "palmpay", name: "PalmPay", icon: Smartphone, description: "Mobile wallet" },
  ];

  const handlePayment = async () => {
    if (!amount || parseFloat(amount) <= 0) {
      alert("Please enter a valid amount");
      return;
    }

    setIsProcessing(true);
    setPaymentStatus("processing");

    // Simulate payment processing
    setTimeout(() => {
      setPaymentStatus("success");
      setIsProcessing(false);
      setTimeout(() => {
        setPaymentStatus("idle");
        setAmount("");
      }, 3000);
    }, 2000);
  };

  if (!isAuthenticated) {
    return (
      <div className="min-h-screen bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-white flex items-center justify-center">
        <Card className="border-purple-500/50 bg-slate-800 w-full max-w-md">
          <CardHeader>
            <CardTitle>Sign In Required</CardTitle>
            <CardDescription>Please sign in to make payments</CardDescription>
          </CardHeader>
        </Card>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-white">
      {/* Navigation */}
      <nav className="sticky top-0 z-40 border-b border-purple-900/30 bg-slate-950/80 backdrop-blur-md">
        <div className="container mx-auto px-4 py-4 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 bg-gradient-to-br from-purple-500 to-purple-900 rounded-lg flex items-center justify-center font-bold text-lg">
              F
            </div>
            <span className="text-xl font-bold bg-gradient-to-r from-purple-400 to-purple-200 bg-clip-text text-transparent">
              FlexHub Payments
            </span>
          </div>
          <Button variant="ghost" className="text-slate-400 hover:text-purple-300">
            ← Back
          </Button>
        </div>
      </nav>

      {/* Payment Container */}
      <div className="container mx-auto px-4 py-12">
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
          {/* Payment Form */}
          <div className="lg:col-span-2">
            <Card className="border-purple-900/50 bg-gradient-to-br from-slate-800 to-slate-900">
              <CardHeader>
                <CardTitle className="text-2xl">Make a Payment</CardTitle>
                <CardDescription>Secure payment processing for FlexHub services</CardDescription>
              </CardHeader>
              <CardContent className="space-y-6">
                {/* Amount Input */}
                <div>
                  <label className="block text-sm font-medium mb-2">Amount (₦)</label>
                  <div className="relative">
                    <span className="absolute left-3 top-3 text-slate-400">₦</span>
                    <Input
                      type="number"
                      placeholder="Enter amount"
                      value={amount}
                      onChange={(e) => setAmount(e.target.value)}
                      className="pl-8 bg-slate-700 border-purple-900/30 text-white placeholder:text-slate-500"
                      disabled={isProcessing}
                    />
                  </div>
                </div>

                {/* Payment Methods */}
                <div>
                  <label className="block text-sm font-medium mb-3">Select Payment Method</label>
                  <div className="grid grid-cols-2 gap-3">
                    {paymentMethods.map((method) => {
                      const Icon = method.icon;
                      return (
                        <button
                          key={method.id}
                          onClick={() => setPaymentMethod(method.id as any)}
                          disabled={isProcessing}
                          className={`p-4 rounded-lg border-2 transition-all ${
                            paymentMethod === method.id
                              ? "border-purple-500 bg-purple-900/30"
                              : "border-purple-900/30 bg-slate-700 hover:border-purple-500"
                          } ${isProcessing ? "opacity-50 cursor-not-allowed" : ""}`}
                        >
                          <Icon className="w-6 h-6 mx-auto mb-2 text-purple-400" />
                          <div className="font-semibold text-sm">{method.name}</div>
                          <div className="text-xs text-slate-400">{method.description}</div>
                        </button>
                      );
                    })}
                  </div>
                </div>

                {/* Payment Status */}
                {paymentStatus === "processing" && (
                  <div className="bg-blue-900/20 border border-blue-500/50 rounded-lg p-4">
                    <p className="text-blue-300">Processing payment... Please wait.</p>
                  </div>
                )}

                {paymentStatus === "success" && (
                  <div className="bg-green-900/20 border border-green-500/50 rounded-lg p-4 flex items-center gap-3">
                    <CheckCircle className="w-5 h-5 text-green-400" />
                    <p className="text-green-300">Payment successful! Transaction ID: TXN-{Date.now()}</p>
                  </div>
                )}

                {paymentStatus === "error" && (
                  <div className="bg-red-900/20 border border-red-500/50 rounded-lg p-4">
                    <p className="text-red-300">Payment failed. Please try again.</p>
                  </div>
                )}

                {/* Payment Button */}
                <Button
                  onClick={handlePayment}
                  disabled={isProcessing || !amount}
                  className="w-full bg-gradient-to-r from-purple-600 to-purple-900 hover:from-purple-700 hover:to-purple-950 text-lg py-6"
                >
                  {isProcessing ? "Processing..." : `Pay ₦${amount || "0"}`}
                </Button>

                {/* Security Info */}
                <div className="bg-slate-700/50 rounded-lg p-4 text-sm text-slate-300">
                  <p className="font-semibold mb-2">🔒 Secure Payment</p>
                  <p>Your payment is encrypted and processed securely through Paystack or Flutterwave. We never store your card details.</p>
                </div>
              </CardContent>
            </Card>
          </div>

          {/* Payment Summary */}
          <div>
            <Card className="border-purple-900/50 bg-gradient-to-br from-slate-800 to-slate-900 sticky top-20">
              <CardHeader>
                <CardTitle>Payment Summary</CardTitle>
              </CardHeader>
              <CardContent className="space-y-4">
                <div className="space-y-2">
                  <div className="flex justify-between text-slate-300">
                    <span>Subtotal:</span>
                    <span>₦{amount || "0"}</span>
                  </div>
                  <div className="flex justify-between text-slate-300">
                    <span>Processing Fee:</span>
                    <span>₦{Math.round((parseFloat(amount) || 0) * 0.015)}</span>
                  </div>
                  <div className="border-t border-purple-900/30 pt-2 flex justify-between font-bold text-purple-300">
                    <span>Total:</span>
                    <span>₦{Math.round((parseFloat(amount) || 0) * 1.015)}</span>
                  </div>
                </div>

                {/* User Info */}
                <div className="bg-slate-700/50 rounded-lg p-3 space-y-2">
                  <div className="text-sm">
                    <span className="text-slate-400">Account:</span>
                    <p className="font-semibold text-white">{user?.name}</p>
                  </div>
                  <div className="text-sm">
                    <span className="text-slate-400">Email:</span>
                    <p className="font-semibold text-white">{user?.email}</p>
                  </div>
                </div>

                {/* FlexPoints Bonus */}
                <div className="bg-gradient-to-br from-yellow-900/30 to-orange-900/30 border border-yellow-500/30 rounded-lg p-3">
                  <p className="text-sm text-yellow-300">
                    💰 Earn {Math.round((parseFloat(amount) || 0) * 0.1)} FlexPoints on this transaction!
                  </p>
                </div>
              </CardContent>
            </Card>
          </div>
        </div>
      </div>
    </div>
  );
}
