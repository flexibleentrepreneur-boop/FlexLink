          </Card>

          <Card className="border-purple-900/50 bg-gradient-to-br from-slate-800 to-slate-900">
            <CardHeader className="pb-3">
              <CardTitle className="text-sm font-medium text-slate-400">Total Views</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="text-3xl font-bold text-purple-400">{totalViews.toLocaleString()}</div>
              <p className="text-xs text-slate-500 mt-2">Across all listings</p>
            </CardContent>
          </Card>

          <Card className="border-purple-900/50 bg-gradient-to-br from-slate-800 to-slate-900">
            <CardHeader className="pb-3">
              <CardTitle className="text-sm font-medium text-slate-400">Rating</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="text-3xl font-bold text-purple-400">4.7★</div>
              <p className="text-xs text-slate-500 mt-2">From 54 reviews</p>
            </CardContent>
          </Card>
        </div>

        {/* Listings Section */}
        <div className="mb-8">
          <div className="flex items-center justify-between mb-6">
            <h2 className="text-2xl font-bold">Your Listings</h2>
            <Button
