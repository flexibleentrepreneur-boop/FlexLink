import { useAuth } from "@/_core/hooks/useAuth";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { useState } from "react";
import { BarChart3, TrendingUp, Users, DollarSign, Plus, Edit2, Trash2, Eye, Star } from "lucide-react";

const mockListings = [
  {
    id: 1,
    title: "3-Bedroom House in Enugu",
    category: "Real Estate",
    price: "₦5,000,000",
    views: 1250,
    inquiries: 45,
    rating: 4.8,
    reviews: 12,
    status: "active",
  },
  {
    id: 2,
    title: "Premium Furniture Set",
    category: "Products",
    price: "₦150,000",
    views: 890,
    inquiries: 28,
    rating: 4.5,
    reviews: 8,
    status: "active",
  },
  {
    id: 3,
    title: "Hair Styling Services",
    category: "Beauty",
    price: "₦5,000",
    views: 2100,
    inquiries: 156,
    rating: 4.9,
    reviews: 34,
    status: "active",
  },
];

const mockBookings = [
  {
    id: 1,
    listingTitle: "3-Bedroom House in Enugu",
    buyer: "Chioma Okafor",
    amount: "₦5,000,000",
    status: "completed",
    date: "2026-04-20",
  },
  {
    id: 2,
    listingTitle: "Hair Styling Services",
    buyer: "Amara Nwosu",
    amount: "₦5,000",
    status: "pending",
    date: "2026-04-27",
  },
  {
    id: 3,
    listingTitle: "Premium Furniture Set",
    buyer: "Emeka Eze",
    amount: "₦150,000",
    status: "completed",
    date: "2026-04-25",
  },
];

export default function ProviderDashboard() {
  const { user, isAuthenticated } = useAuth();
  const [showNewListingForm, setShowNewListingForm] = useState(false);
  const [newListing, setNewListing] = useState({ title: "", category: "", price: "" });

  if (!isAuthenticated) {
    return (
      <div className="min-h-screen bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-white flex items-center justify-center">
        <Card className="border-purple-500/50 bg-slate-800 w-full max-w-md">
          <CardHeader>
            <CardTitle>Sign In Required</CardTitle>
            <CardDescription>Please sign in as a provider to access this dashboard</CardDescription>
          </CardHeader>
        </Card>
      </div>
    );
  }

  const totalEarnings = 5_150_000;
  const totalListings = mockListings.length;
  const totalBookings = mockBookings.length;
  const totalViews = mockListings.reduce((sum, l) => sum + l.views, 0);

  return (
    <div className="min-h-screen bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-white">
      {/* Navigation */}
      <nav className="sticky top-0 z-40 border-b border-purple-900/30 bg-slate-950/80 backdrop-blur-md">
        <div className="container mx-auto px-4 py-4 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 bg-gradient-to-br from-purple-500 to-purple-900 rounded-lg flex items-center justify-center font-bold text-lg">
              F
            </div>
            <span className="text-xl font-bold bg-gradient-to-r from-purple-400 to-purple-200 bg-clip-text text-transparent">
              Provider Dashboard
            </span>
          </div>
          <div className="flex items-center gap-4">
            <Button variant="ghost" className="text-slate-400 hover:text-purple-300">
              Profile
            </Button>
            <Button variant="ghost" className="text-slate-400 hover:text-purple-300">
              Settings
            </Button>
          </div>
        </div>
      </nav>

      {/* Main Content */}
      <div className="container mx-auto px-4 py-12">
        {/* Header */}
        <div className="mb-8">
          <h1 className="text-4xl font-bold mb-2">
            Welcome, <span className="bg-gradient-to-r from-purple-400 to-purple-200 bg-clip-text text-transparent">{user?.name}</span>
          </h1>
          <p className="text-slate-300">Manage your listings, bookings, and earnings</p>
        </div>

        {/* Key Metrics */}
        <div className="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
          <Card className="border-purple-900/50 bg-gradient-to-br from-slate-800 to-slate-900">
            <CardHeader className="pb-3">
              <CardTitle className="text-sm font-medium text-slate-400">Total Earnings</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="text-3xl font-bold text-purple-400">₦{totalEarnings.toLocaleString()}</div>
              <p className="text-xs text-slate-500 mt-2">From {totalBookings} completed bookings</p>
            </CardContent>
          </Card>

          <Card className="border-purple-900/50 bg-gradient-to-br from-slate-800 to-slate-900">
            <CardHeader className="pb-3">
              <CardTitle className="text-sm font-medium text-slate-400">Active Listings</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="text-3xl font-bold text-purple-400">{totalListings}</div>
              <p className="text-xs text-slate-500 mt-2">All verified and active</p>
