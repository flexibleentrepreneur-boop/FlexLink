import { useAuth } from "@/_core/hooks/useAuth";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { trpc } from "@/lib/trpc";
import { TrendingUp, Heart, Zap, Award, Calendar, MessageSquare } from "lucide-react";
import { useLocation } from "wouter";

export default function Dashboard() {
  const { user, isAuthenticated } = useAuth();
  const [, navigate] = useLocation();

  const { data: bookings } = trpc.bookings.myBookings.useQuery(undefined, {
    enabled: isAuthenticated,
  });

  const { data: wellnessMetrics } = trpc.wellness.metrics.useQuery(undefined, {
    enabled: isAuthenticated,
  });

  if (!isAuthenticated) {
    return (
      <div className="min-h-screen bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-white flex items-center justify-center">
        <Card className="border-purple-500/50 bg-slate-800 w-full max-w-md">
          <CardHeader>
            <CardTitle>Please Sign In</CardTitle>
            <CardDescription>You need to be logged in to access your dashboard</CardDescription>
          </CardHeader>
          <CardContent>
            <Button className="w-full bg-gradient-to-r from-purple-600 to-purple-900 hover:from-purple-700 hover:to-purple-950">
              Sign In
            </Button>
          </CardContent>
        </Card>
      </div>
    );
  }

  const recentBookings = bookings?.slice(0, 5) || [];
  const latestWellness = wellnessMetrics?.[wellnessMetrics.length - 1];

  return (
    <div className="min-h-screen bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-white">
      {/* Navigation */}
      <nav className="sticky top-0 z-40 border-b border-purple-900/30 bg-slate-950/80 backdrop-blur-md">
        <div className="container mx-auto px-4 py-4 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 bg-gradient-to-br from-purple-500 to-purple-900 rounded-lg flex items-center justify-center font-bold text-lg">
              F
            </div>
            <span className="text-xl font-bold bg-gradient-to-r from-purple-400 to-purple-200 bg-clip-text text-transparent">
              FlexHub Dashboard
            </span>
          </div>
          <div className="flex items-center gap-4">
            <Button variant="ghost" className="text-slate-400 hover:text-purple-300">
              Profile
            </Button>
            <Button variant="ghost" className="text-slate-400 hover:text-purple-300">
              Settings
            </Button>
          </div>
        </div>
      </nav>

      {/* Welcome Section */}
      <section className="container mx-auto px-4 py-12">
        <div className="mb-8">
          <h1 className="text-4xl font-bold mb-2">
            Welcome back, <span className="bg-gradient-to-r from-purple-400 to-purple-200 bg-clip-text text-transparent">{user?.name || "Entrepreneur"}</span>
          </h1>
          <p className="text-slate-300">Here's your business health overview</p>
        </div>

        {/* Key Metrics */}
        <div className="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
          <Card className="border-purple-900/50 bg-gradient-to-br from-slate-800 to-slate-900">
            <CardHeader className="pb-3">
              <CardTitle className="text-sm font-medium text-slate-400">FlexPoints</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="text-3xl font-bold text-purple-400">{user?.flexPoints || 0}</div>
              <p className="text-xs text-slate-500 mt-2">Earn by transactions & referrals</p>
            </CardContent>
          </Card>

          <Card className="border-purple-900/50 bg-gradient-to-br from-slate-800 to-slate-900">
            <CardHeader className="pb-3">
              <CardTitle className="text-sm font-medium text-slate-400">Active Bookings</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="text-3xl font-bold text-purple-400">{bookings?.filter(b => b.status === 'pending' || b.status === 'confirmed').length || 0}</div>
              <p className="text-xs text-slate-500 mt-2">Ongoing transactions</p>
            </CardContent>
          </Card>

          <Card className="border-purple-900/50 bg-gradient-to-br from-slate-800 to-slate-900">
            <CardHeader className="pb-3">
              <CardTitle className="text-sm font-medium text-slate-400">Verification</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="text-3xl font-bold text-purple-400">{user?.verified ? "✓" : "Pending"}</div>
              <p className="text-xs text-slate-500 mt-2">Account status</p>
            </CardContent>
          </Card>

          <Card className="border-purple-900/50 bg-gradient-to-br from-slate-800 to-slate-900">
            <CardHeader className="pb-3">
              <CardTitle className="text-sm font-medium text-slate-400">Member Since</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="text-3xl font-bold text-purple-400">
                {user?.createdAt ? new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) : 'N/A'}
              </div>
              <p className="text-xs text-slate-500 mt-2">Account age</p>
            </CardContent>
          </Card>
        </div>
      </section>

      {/* Business Health Dashboard */}
      <section className="container mx-auto px-4 py-8">
        <h2 className="text-2xl font-bold mb-6">Business Health</h2>
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
          {/* Wellness Metrics */}
          <Card className="border-purple-900/50 bg-gradient-to-br from-slate-800 to-slate-900 lg:col-span-2">
            <CardHeader>
              <CardTitle className="flex items-center gap-2">
                <Heart className="w-5 h-5 text-red-400" />
                Wellness Tracking
              </CardTitle>
              <CardDescription>Your mental health and stress levels</CardDescription>
            </CardHeader>
            <CardContent>
              <div className="space-y-4">
                {latestWellness ? (
                  <>
                    <div>
                      <div className="flex justify-between mb-2">
                        <span className="text-sm font-medium">Mood</span>
                        <span className="text-sm text-purple-400 capitalize">{latestWellness.mood || 'Not tracked'}</span>
                      </div>
                      <div className="w-full bg-slate-700 rounded-full h-2"></div>
                    </div>
                    <div>
                      <div className="flex justify-between mb-2">
                        <span className="text-sm font-medium">Stress Level</span>
                        <span className="text-sm text-purple-400">{latestWellness.stressLevel || 5}/10</span>
                      </div>
                      <div className="w-full bg-slate-700 rounded-full h-2">
                        <div
                          className="bg-gradient-to-r from-yellow-500 to-red-500 h-2 rounded-full"
                          style={{ width: `${((latestWellness.stressLevel || 5) / 10) * 100}%` }}
                        ></div>
                      </div>
                    </div>
                    <div>
                      <div className="flex justify-between mb-2">
                        <span className="text-sm font-medium">Business Load</span>
                        <span className="text-sm text-purple-400">{latestWellness.businessLoad || 5}/10</span>
                      </div>
                      <div className="w-full bg-slate-700 rounded-full h-2">
                        <div
                          className="bg-gradient-to-r from-blue-500 to-purple-500 h-2 rounded-full"
                          style={{ width: `${((latestWellness.businessLoad || 5) / 10) * 100}%` }}
                        ></div>
                      </div>
                    </div>
                  </>
                ) : (
                  <p className="text-slate-400">No wellness data yet. Start tracking your wellness today!</p>
                )}
                <Button className="w-full mt-4 bg-gradient-to-r from-purple-600 to-purple-900 hover:from-purple-700 hover:to-purple-950">
                  Update Wellness
                </Button>
              </div>
            </CardContent>
          </Card>

          {/* Quick Actions */}
          <Card className="border-purple-900/50 bg-gradient-to-br from-slate-800 to-slate-900">
            <CardHeader>
              <CardTitle className="flex items-center gap-2">
                <Zap className="w-5 h-5 text-yellow-400" />
                Quick Actions
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-3">
              <Button className="w-full bg-gradient-to-r from-purple-600 to-purple-900 hover:from-purple-700 hover:to-purple-950 justify-start">
                <MessageSquare className="w-4 h-4 mr-2" />
                Talk to Flex Guide
              </Button>
              <Button variant="outline" className="w-full border-purple-500 text-purple-400 hover:bg-purple-900/20 justify-start">
                <TrendingUp className="w-4 h-4 mr-2" />
                View Analytics
              </Button>
              <Button variant="outline" className="w-full border-purple-500 text-purple-400 hover:bg-purple-900/20 justify-start">
                <Award className="w-4 h-4 mr-2" />
                Redeem FlexPoints
              </Button>
              <Button variant="outline" className="w-full border-purple-500 text-purple-400 hover:bg-purple-900/20 justify-start">
                <Calendar className="w-4 h-4 mr-2" />
                Schedule Session
              </Button>
            </CardContent>
          </Card>
        </div>
      </section>

      {/* Recent Bookings */}
      <section className="container mx-auto px-4 py-8">
        <h2 className="text-2xl font-bold mb-6">Recent Bookings</h2>
        {recentBookings.length > 0 ? (
          <div className="space-y-4">
            {recentBookings.map((booking) => (
              <Card key={booking.id} className="border-purple-900/50 bg-gradient-to-br from-slate-800 to-slate-900">
                <CardContent className="pt-6">
                  <div className="flex items-center justify-between">
                    <div>
                      <h3 className="font-semibold text-white">Booking #{booking.id}</h3>
                      <p className="text-sm text-slate-400">
                        Status: <span className="text-purple-400 capitalize">{booking.status}</span>
                      </p>
                    </div>
                    <div className="text-right">
                      <div className="text-lg font-bold text-purple-400">
                        ₦{Number(booking.totalPrice).toLocaleString()}
                      </div>
                      <p className="text-sm text-slate-400">
                        {new Date(booking.createdAt).toLocaleDateString()}
                      </p>
                    </div>
                  </div>
                </CardContent>
              </Card>
            ))}
          </div>
        ) : (
          <Card className="border-purple-900/50 bg-gradient-to-br from-slate-800 to-slate-900">
            <CardContent className="pt-6 text-center">
              <p className="text-slate-400 mb-4">No bookings yet. Start exploring categories!</p>
              <Button className="bg-gradient-to-r from-purple-600 to-purple-900 hover:from-purple-700 hover:to-purple-950">
                Browse Categories
              </Button>
            </CardContent>
          </Card>
        )}
      </section>
    </div>
  );
}
